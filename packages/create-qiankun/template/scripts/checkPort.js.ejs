// Fork from get-port with modifications for qiankun
const os = require('os');
const net = require('net');

let pkgName;
try {
  const pkg = require('../package.json');
  pkgName = pkg.name || 'Unknown Application';
} catch (error) {
  pkgName = 'Unknown Application';
}

const port = <%= port %>;

async function checkPortIsOccupied() {
  if (!port || isNaN(port) || port <= 0 || port > 65535) {
    throw new Error(`Invalid port number: ${port}`);
  }

  const hosts = getLocalHosts();
  const errors = [];

  for (const host of hosts) {
    try {
      await checkAvailablePort({ port, host });
    } catch (error) {
      if (!['EADDRNOTAVAIL', 'EINVAL'].includes(error.code)) {
        errors.push({ host, error: error.message });
      }
    }
  }

  if (errors.length === hosts.size) {
    throw new Error(`Port ${port} is occupied on all network interfaces`);
  }
}

async function main() {
  try {
    console.log(`\u001b[36mChecking port ${port} availability for application: ${pkgName}\u001b[39m`);
    
    await checkPortIsOccupied();
    
    console.log(`\u001b[32m✓ Port ${port} is available for ${pkgName}\u001b[39m\n`);
  } catch (error) {
    console.error(`\u001b[31m✗ Port check failed for ${pkgName}:\u001b[39m`);
    console.error(`\u001b[33m  Port ${port} is occupied. Please ensure no other services are using this port.\u001b[39m`);
    console.error(`\u001b[33m  If you want to change the port, please update the sub-application information registered in the main application.\u001b[39m`);
    console.error(`\u001b[33m  Otherwise, qiankun may fail to load the sub-application resources.\u001b[39m\n`);
    
    console.error(`\u001b[90mError details: ${error.message}\u001b[39m`);
    
    process.exit(1);
  }
}

function checkAvailablePort(options) {
  return new Promise((resolve, reject) => {
    const server = net.createServer();
    server.unref();
    server.on('error', reject);

    server.listen(options, () => {
      const { port: serverPort } = server.address();
      server.close(() => {
        resolve(serverPort);
      });
    });
  });
}

function getLocalHosts() {
  const interfaces = os.networkInterfaces();
  const results = new Set([undefined, '0.0.0.0']);

  for (const interfaceList of Object.values(interfaces)) {
    if (!interfaceList) continue;
    
    for (const config of interfaceList) {
      if (config && config.address) {
        results.add(config.address);
      }
    }
  }

  return results;
}

// Run the main function
main();
